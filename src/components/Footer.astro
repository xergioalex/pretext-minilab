---
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href={base} class="footer-logo">
        <span class="logo-icon">P</span>
        <span>Pretext Lab</span>
      </a>
      <p class="footer-desc">
        An interactive exploration of programmable text layout with
        <a href="https://github.com/chenglou/pretext" target="_blank" rel="noopener">@chenglou/pretext</a>.
        Built with Astro + Svelte.
      </p>
    </div>
    <div class="footer-right">
      <div class="footer-col">
        <h4>Project</h4>
        <a href="https://github.com/xergioalex/pretext-minilab" target="_blank" rel="noopener">GitHub Repository</a>
        <a href="https://github.com/chenglou/pretext" target="_blank" rel="noopener">Pretext Library</a>
      </div>
      <div class="footer-col">
        <h4>Built with</h4>
        <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
        <a href="https://svelte.dev" target="_blank" rel="noopener">Svelte</a>
      </div>
      <div class="footer-col">
        <h4>Author</h4>
        <a href="https://xergioalex.com" target="_blank" rel="noopener">xergioalex.com</a>
        <a href="https://github.com/xergioalex" target="_blank" rel="noopener">GitHub</a>
        <a href="https://linkedin.com/in/xergioalex" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://x.com/XergioAleX" target="_blank" rel="noopener">X / Twitter</a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>
      Made by <a href="https://xergioalex.com" target="_blank" rel="noopener">Sergio Florez (XergioAleX)</a>
      &middot; Static site with interactive islands &middot; Deployed to GitHub Pages
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    background: var(--bg-secondary);
    padding: var(--space-3xl) 0 var(--space-xl);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2xl);
    flex-wrap: wrap;
  }

  .footer-left {
    max-width: 380px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: var(--space-md);
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-sm);
    font-weight: 800;
    font-size: 0.85rem;
  }

  .footer-desc {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .footer-right {
    display: flex;
    gap: var(--space-3xl);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-col h4 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin-bottom: var(--space-xs);
  }

  .footer-col a {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-col a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-bottom a {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .footer-bottom a:hover {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
    }
    .footer-right {
      flex-direction: column;
      gap: var(--space-xl);
    }
  }
</style>
