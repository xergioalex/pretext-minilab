---
import DemoLayout from '../../layouts/DemoLayout.astro';
import TextBreakoutIsland from '../../islands/demos/TextBreakout.svelte';
---

<DemoLayout
  title="Text Breakout"
  summary="Classic Breakout, but the bricks are words. Smash them and watch the surviving text reflow instantly."
  context="Every brick is a word from a paragraph, positioned using Pretext. When you destroy a word, the remaining text is re-layouted with layoutWithLines() and the bricks repack — a live demonstration of instant text relayout as a game mechanic."
  apis={['prepareWithSegments()', 'layoutWithLines()']}
  difficulty="Game"
  snippet={`import { prepareWithSegments, layoutWithLines } from '@chenglou/pretext';

// Layout paragraph to get word positions (bricks)
const prepared = prepareWithSegments(paragraph, '14px Inter');
const result = layoutWithLines(prepared, gameWidth, 22);

// Each word becomes a breakable brick
const bricks = extractWords(result.lines);

// When a brick is destroyed, relayout surviving text
function onBrickDestroyed(word: string) {
  const remaining = survivingWords.join(' ');
  const newLayout = layoutWithLines(
    prepareWithSegments(remaining, font), gameWidth, 22
  );
  // Bricks repack instantly — no layout shift
}`}
>
  <div class="demo-area" slot="demo">
    <TextBreakoutIsland client:only="svelte" />
  </div>

  <div class="demo-info" slot="info">
    <div class="info-card">
      <h3>What this demonstrates</h3>
      <p>
        Text relayout as a game mechanic. Each word-brick is positioned using Pretext's line layout.
        When bricks are destroyed, surviving words are re-layouted instantly — the paragraph condenses
        in real time. This shows Pretext's ability to relayout cheaply and continuously.
      </p>
    </div>
    <div class="info-card">
      <h3>Relevant Pretext API</h3>
      <ul>
        <li><code>prepareWithSegments()</code> — measure all words</li>
        <li><code>layoutWithLines()</code> — position words as lines, re-run on every brick destruction</li>
      </ul>
    </div>
    <div class="info-card">
      <h3>How to play</h3>
      <p>
        Click to start. Move your mouse to control the paddle. Bounce the ball into word-bricks
        to destroy them. Watch the remaining words reflow into tighter lines as you play.
      </p>
    </div>
  </div>
</DemoLayout>
