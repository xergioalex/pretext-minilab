---
import BaseLayout from '../layouts/BaseLayout.astro';
import DemoSwitcherIsland from '../islands/DemoSwitcher.svelte';
import { demos } from '../lib/content/demos';
import { categoryColors, demoIcons } from '../lib/content/demoVisuals';

const base = import.meta.env.BASE_URL;
const demoCount = demos.length;
---

<BaseLayout
  title="Pretext Lab — Programmable Text Layout for the Web"
  description={`${demoCount} interactive demos exploring programmable text layout with @chenglou/pretext. Prepare text once, layout at any width instantly — no DOM reflow needed.`}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Pretext Lab',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Web',
    url: 'https://pretext.xergioalex.com',
    description: `${demoCount} interactive demos for programmable text layout with @chenglou/pretext — from basic measurement to physics simulations, all running at 60fps without DOM reflow.`,
    author: { '@type': 'Person', name: 'Sergio Alexander Florez Galeano', url: 'https://xergioalex.com' },
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    isAccessibleForFree: true,
    inLanguage: 'en',
    keywords: 'text layout, pretext, typography, javascript, interactive demos, canvas, web development',
  }}
>
  <section class="hero">
    <div class="container hero-inner">
      <h1 class="hero-title">
        <img class="hero-logo hero-logo-dark" src={`${base}logos/logo-dark.png`} alt="Pretext Lab" />
        <img class="hero-logo hero-logo-light" src={`${base}logos/logo-light.png`} alt="Pretext Lab" />
      </h1>
      <p class="hero-sub">
        Interactive demos exploring programmable text layout with
        <a href="https://github.com/chenglou/pretext" target="_blank" rel="noopener">@chenglou/pretext</a>.
        <code>prepare()</code> once, <code>layout()</code> at any width — instantly.
      </p>
      <p class="hero-author">
        by <a href="https://xergioalex.com" target="_blank" rel="noopener">Sergio Florez (XergioAleX)</a>
        &middot;
        <a href="https://xergioalex.com/blog/pretext-programmable-text-layout/" target="_blank" rel="noopener" class="hero-article-link">Read the deep dive</a>
      </p>
    </div>
  </section>

  <DemoSwitcherIsland client:only="svelte" baseUrl={base} />

  <section class="demos-section">
    <div class="container">
      <div class="demos-header">
        <h2 class="demos-title">All {demoCount} Demos</h2>
        <button class="search-demos-btn" id="search-demos-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          <span>Search demos...</span>
        </button>
      </div>
      <div class="demo-grid">
        {demos.map((demo) => (
          <a href={`${base}demos/${demo.slug}/`} class:list={['demo-card', { flagship: demo.flagship }]}>
            <div class="card-body">
              <div class="card-top">
                <span class="card-dot" style={`background: ${categoryColors[demo.category]}`}></span>
                <span class="card-difficulty">{demo.difficulty}</span>
                {demo.flagship && <span class="flagship-tag">Flagship</span>}
              </div>
              <h2 class="card-title">
                <span class="card-emoji">{demoIcons[demo.slug] || '🔬'}</span>
                {demo.title}
              </h2>
              <p class="card-summary">{demo.summary}</p>
              <div class="card-apis">
                {demo.apis.map((api) => <code>{api}</code>)}
              </div>
            </div>
            <div class="card-arrow">→</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-lg);
    position: relative;
    border-bottom: 1px solid var(--border);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    text-align: center;
  }

  .hero-title {
    margin-bottom: var(--space-sm);
    line-height: 1;
  }

  .hero-logo {
    height: clamp(48px, 8vw, 72px);
    width: auto;
  }

  .hero-logo-dark { display: none; }
  .hero-logo-light { display: none; }

  :global([data-theme="dark"]) .hero-logo-dark { display: inline; }
  :global([data-theme="light"]) .hero-logo-light { display: inline; }

  .hero-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-sub a {
    font-weight: 600;
  }

  .hero-author {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: var(--space-sm);
    text-align: center;
  }

  .hero-author a {
    color: var(--text-secondary);
    font-weight: 600;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .hero-author a:hover {
    color: var(--accent);
  }

  .hero-article-link {
    color: var(--accent);
    opacity: 0.8;
  }

  .hero-article-link:hover {
    opacity: 1;
  }

  .demos-section {
    padding: var(--space-2xl) 0 var(--space-4xl);
  }

  .demos-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
  }

  .demos-title {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .search-demos-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-muted);
    font-size: 0.85rem;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .search-demos-btn:hover {
    border-color: var(--accent);
    color: var(--text-secondary);
    background: var(--bg-card-hover);
  }

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 1024px) {
    .demo-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .demo-grid { grid-template-columns: 1fr; }
  }

  .demo-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg) var(--space-xl);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
    cursor: pointer;
    position: relative;
  }

  .demo-card:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(124, 108, 240, 0.1);
    color: inherit;
  }

  .demo-card.flagship {
    border-color: var(--border-accent);
    background: linear-gradient(135deg, var(--bg-card) 0%, var(--accent-dim) 100%);
  }

  .card-body {
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .card-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .card-difficulty {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .flagship-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15em 0.6em;
    border-radius: 9999px;
    background: var(--accent);
    color: #fff;
  }

  .card-emoji {
    margin-right: 6px;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }

  .card-summary {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .card-apis {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: var(--space-sm);
  }

  .card-apis code {
    font-size: 0.68rem;
    padding: 0.15em 0.4em;
    background: var(--bg-surface);
    border: 1px solid var(--border);
  }

  .card-arrow {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-xl);
    font-size: 1.2rem;
    color: var(--text-muted);
    transition: all var(--transition-fast);
  }

  .demo-card:hover .card-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .demo-grid {
      grid-template-columns: 1fr;
    }
    .demo-card.flagship {
      grid-column: 1;
    }
  }
</style>

<script>
  document.getElementById('search-demos-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-demo-switcher'));
  });
</script>
